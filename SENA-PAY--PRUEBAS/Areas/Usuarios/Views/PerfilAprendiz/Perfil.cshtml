@{
    ViewData["Title"] = "Mi Carnet Digital";
}

<div class="container mt-5 d-flex justify-content-center">
    <div class="card shadow-lg border-0" style="width: 350px; border-radius: 20px; overflow: hidden;">
        <div style="background: linear-gradient(135deg, #009955 0%, #006b3c 100%); padding: 25px;">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="text-white fw-bold m-0">SENA-PAY</h5>
                <i class="bi bi-cpu-fill text-white fs-4"></i>
            </div>
        </div>

        <div class="card-body text-center p-4">
            <div class="mb-3">
                <div class="rounded-circle bg-light d-inline-flex align-items-center justify-content-center border border-3 border-success" style="width: 100px; height: 100px;">
                    <i class="bi bi-person-fill text-success" style="font-size: 50px;"></i>
                </div>
            </div>

            <h4 class="fw-bold text-uppercase mb-1">@ViewBag.Nombre</h4>
            <p class="text-muted small mb-4">Aprendiz • Ficha @ViewBag.Ficha</p>

            <div class="p-3 mb-4" style="background-color: #f8f9fa; border-radius: 15px;">
                <span class="text-secondary small d-block">Saldo Actual</span>
                <h2 class="fw-bold text-success m-0">$@ViewBag.Saldo</h2>
            </div>

            <div class="row border-top pt-3">
                <div class="col-6 border-end">
                    <small class="text-muted d-block">Estado</small>
                    <span class="badge bg-success">Activo</span>
                </div>
                <div class="col-6">
                    <small class="text-muted d-block">Tipo</small>
                    <span class="fw-bold small">Presencial</span>
                </div>
            </div>
        </div>

        <div class="p-3 bg-light">
            <a asp-area="Tienda"
               asp-controller="Productos"
               asp-action="Index"
               class="btn btn-success w-100 fw-bold py-2 shadow-sm"
               style="border-radius: 10px;">
                <i class="bi bi-cart3 me-2"></i> Ir a la Tienda
            </a>
        </div>
    </div>
</div>
